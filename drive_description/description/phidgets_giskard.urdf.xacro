<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="phidgets_6wheel">

  <xacro:property name="body_length" value="0.9"/>
  <xacro:property name="body_width" value="0.55"/>
  <xacro:property name="body_height" value="0.18"/>
  <xacro:property name="wheel_radius" value="0.0925"/> 
  <xacro:property name="wheel_width" value="0.06"/>
  <xacro:property name="front_x" value="0.28"/>
  <xacro:property name="middle_x" value="0.0"/>
  <xacro:property name="rear_x" value="-0.28"/>
  <xacro:property name="left_y" value="0.33"/>
  <xacro:property name="right_y" value="-0.33"/>
  <xacro:property name="ground_clearance" value="0.03"/>
  <xacro:property name="body_visual_z" value="${wheel_radius + ground_clearance + body_height / 2.0}"/>
  <xacro:property name="wheel_z" value="${wheel_radius}"/>

  <material name="body_blue">
    <color rgba="0.12 0.25 0.42 1.0"/>
  </material>

  <material name="wheel_black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${body_visual_z}" rpy="0 0 0"/>
      <geometry>
        <box size="${body_length} ${body_width} ${body_height}"/>
      </geometry>
      <material name="body_blue"/>
    </visual>
  </link>

  <!-- LEFT SIDE WHEELS -->
  <link name="front_left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="wheel_black"/>
    </visual>
  </link>
  
  <link name="middle_left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="wheel_black"/>
    </visual>
  </link>

  <link name="rear_left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="wheel_black"/>
    </visual>
  </link>

  <!-- RIGHT SIDE WHEELS -->
  <link name="front_right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="wheel_black"/>
    </visual>
  </link>

  <link name="middle_right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="wheel_black"/>
    </visual>
  </link>

  <link name="rear_right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="wheel_black"/>
    </visual>
  </link>

  <!-- LEFT SIDE JOINTS -->
  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <origin xyz="${front_x} ${left_y} ${wheel_z}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="middle_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="middle_left_wheel"/>
    <origin xyz="${middle_x} ${left_y} ${wheel_z}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="rear_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_left_wheel"/>
    <origin xyz="${rear_x} ${left_y} ${wheel_z}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- RIGHT SIDE JOINTS -->
  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <origin xyz="${front_x} ${right_y} ${wheel_z}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="middle_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="middle_right_wheel"/>
    <origin xyz="${middle_x} ${right_y} ${wheel_z}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="rear_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_right_wheel"/>
    <origin xyz="${rear_x} ${right_y} ${wheel_z}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <ros2_control name="PhidgetsBLDC" type="system">
    <hardware>
      <plugin>phidgets_hardware/PhidgetsBldcHardware</plugin>
      <param name="gear_ratio">106.0</param>
      <param name="acceleration">5.0</param>
      <param name="stall_velocity">0.0</param>
      <param name="commutations_per_motor_rev">24</param>
      <param name="command_limit">1.0</param>
      <param name="attachment_retry_period_sec">1.0</param>
    </hardware>

    <!-- LEFT SIDE - ALL 3 WHEELS -->
    <joint name="front_left_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="middle_left_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="rear_left_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <!-- RIGHT SIDE - ALL 3 WHEELS -->
    <joint name="front_right_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="middle_right_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="rear_right_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    
  </ros2_control>

</robot>